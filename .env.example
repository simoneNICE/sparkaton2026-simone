# "Learned" (recall) routing algorithm — points at the standalone fuzzy prompt
# matcher (Python/Flask, sibling repo "Model Routing", app.py). Defaults to
# http://127.0.0.1:5050 if unset. Only used when the "Learned" checkbox is on;
# if the service isn't running, recall silently misses and falls back to the
# metadata-based router.
# RECALL_SERVICE_URL=http://127.0.0.1:5050

# The router itself is deterministic and needs no keys. The Bedrock connector
# (lib/bedrock.ts, /api/bedrock) DOES call AWS, so it needs credentials + region.

# --- AWS Bedrock connector ---
# Region where you have Bedrock model access enabled.
BEDROCK_REGION=us-east-1
# AWS_REGION is used as a fallback if BEDROCK_REGION is unset.
# AWS_REGION=us-east-1

# Geo prefix for cross-region inference profiles (Claude + Nova): "us" | "eu" | "apac".
BEDROCK_GEO=us

# Credentials: leave UNSET on AWS (Amplify/App Runner/ECS use the attached IAM
# role automatically). For LOCAL dev, either run `aws sso login` / set a profile,
# or uncomment and fill these:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- Future ---
# CLAUDE_CLI_PATH=claude
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
